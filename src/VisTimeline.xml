<?xml version="1.0" encoding="utf-8"?>
<widget id="stoneworx.vistimeline.VisTimeline" pluginWidget="true" needsEntityContext="true" offlineCapable="true"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Vis Timeline</name>
    <description>Vis Timeline Mendix Pluggable Widget based on https://github.com/visjs/vis-timeline.</description>
    <icon/>
    <properties>
        <propertyGroup caption="Groups">
            <property key="VisGroupsDataSource" type="datasource" isList="true">
                <caption>Group Source</caption>
                <description>The source entity for the timeline rows (groups).</description>
            </property>
            <property key="GroupIDAttr" type="attribute" dataSource="VisGroupsDataSource">
                <caption>Group ID</caption>
                <description>Unique identifier for the group (typically an Integer or AutoNumber).</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Integer"/>
                    <attributeType name="AutoNumber"/>
                </attributeTypes>
            </property>
            <property key="GroupContentAttr" type="attribute" dataSource="VisGroupsDataSource">
                <caption>Group Content</caption>
                <description>The label displayed on the left side of the timeline.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                </attributeTypes>
            </property>
            <property key="GroupValue" type="attribute" dataSource="VisGroupsDataSource">
                <caption>Value</caption>
                <description />
                <attributeTypes>
                    <attributeType name="Integer" />
                </attributeTypes>
            </property>
            <property key="GroupClassName" type="attribute" dataSource="VisGroupsDataSource">
                <caption>Class Name</caption>
                <description />
                <attributeTypes>
                    <attributeType name="String" />
                </attributeTypes>
            </property>
            <property key="groupAssociation" type="association" selectableObjects="VisGroupsDataSource" dataSource="VisGroupsDataSource" required="false">
                <caption>Parent (self-association)</caption>
                <description>Reference to the child Group (can be empty)</description>
                    <associationTypes>
                        <associationType name="ReferenceSet"/>
                    </associationTypes>
            </property>
            <property key="groupVisible" type="attribute" dataSource="VisGroupsDataSource" required="false">
                <caption>Group Visible?</caption>
                <description />
                <attributeTypes>
                    <attributeType name="Boolean" />
                </attributeTypes>
            </property>
            <property key="groupShowNested" type="attribute" dataSource="VisGroupsDataSource" required="false">
                <caption>Show Nested Groups?</caption>
                <description />
                <attributeTypes>
                    <attributeType name="Boolean" />
                </attributeTypes>
            </property>
        </propertyGroup>
        <propertyGroup caption="Items">
             <property key="VisItemsDataSource" type="datasource" isList="true">
                <caption>Items</caption>
                <description />
            </property>
            <property key="ItemID" type="attribute" dataSource="VisItemsDataSource">
                <caption>Item ID</caption>
                <description />
                <attributeTypes>
                    <attributeType name="Integer" />
                    <attributeType name="String" />
                </attributeTypes>
            </property>
            <property key="ItemGroupID" type="attribute" dataSource="VisItemsDataSource">
                <caption>Item Group ID</caption>
                <description>This value must match the Group ID above to place the item in the correct row.</description>
                <attributeTypes>
                    <attributeType name="String"/>
                    <attributeType name="Integer"/>
                </attributeTypes>
            </property>
            <property key="ItemContent" type="attribute" dataSource="VisItemsDataSource">
                <caption>Content</caption>
                <description />
                <attributeTypes>
                    <attributeType name="String" />
                </attributeTypes>
            </property>
            <property key="Start" type="attribute" dataSource="VisItemsDataSource">
                <caption>Start</caption>
                <description />
                <attributeTypes>
                    <attributeType name="DateTime" />
                </attributeTypes>
            </property>
            <property key="End" type="attribute" dataSource="VisItemsDataSource">
                <caption>End</caption>
                <description />
                <attributeTypes>
                    <attributeType name="DateTime" />
                </attributeTypes>
            </property>
            <property key="Type" type="attribute" dataSource="VisItemsDataSource" required="false">
                <caption>Type</caption>
                <description />
                <attributeTypes>
                    <attributeType name="Enum" />
                </attributeTypes>
            </property>
            <property key="ItemClassName" type="attribute" dataSource="VisItemsDataSource">
                <caption>Class Name</caption>
                <description />
                <attributeTypes>
                    <attributeType name="String" />
                </attributeTypes>
            </property>
        </propertyGroup>
         <propertyGroup caption="Options">
            <!-- <propertyGroup caption="Main">
            </propertyGroup>
            <propertyGroup caption="Editability">
            </propertyGroup> -->
            <propertyGroup caption="Snapping">
                <property key="IsSnap" type="expression">
                    <caption>Apply snapping?</caption>
                    <description />
                    <returnType type="Boolean" />
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Events">
            <property key="clickAction" type="action">
                <caption>On click</caption>
                <description>Action to be performed when item is clicked.</description>
                <actionVariables>
                    <actionVariable key="clickedItemID" type="String" caption="Clicked Item ID" />
                </actionVariables>
            </property>
            <property key="doubleClickAction" type="action">
                <caption>On double click</caption>
                <description>Action to be performed when item is double-clicked.</description>
                <actionVariables>
                    <actionVariable key="doubleClickedItemID" type="String" caption="Double clicked Item ID" />
                </actionVariables>
            </property>
            <property key="onAddAction" type="action">
                <caption>On Add</caption>
                <description>Action to be performed when item is added.</description>
                <actionVariables>
                    <actionVariable key="data" type="String" caption="Added Item Stringified JSON" />
                </actionVariables>
            </property>
            <property key="onUpdateAction" type="action">
                <caption>On Update</caption>
                <description>Action to be performed when item is updated.</description>
                <actionVariables>
                    <actionVariable key="data" type="String" caption="Updated Item Stringified JSON" />
                </actionVariables>
            </property>
            <property key="onRemoveAction" type="action">
                <caption>On Remove</caption>
                <description>Action to be performed when item is removed.</description>
                <actionVariables>
                    <actionVariable key="data" type="String" caption="Removed Item Stringified JSON" />
                </actionVariables>
            </property>
             <property key="onInitialDrawCompleteAction" type="action">
                <caption>On Initial Draw Complete</caption>
                <description>Action to be performed when the timeline is drawn for the first time.</description>
            </property>
        </propertyGroup>
    </properties>
</widget>